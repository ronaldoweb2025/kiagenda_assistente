{
  "manifest_version": 3,
  "name": "KiAgenda Assistente",
  "description": "Atendimento simples no WhatsApp para a versao Essencial do KiAgenda Assistente.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "KiAgenda Assistente",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
